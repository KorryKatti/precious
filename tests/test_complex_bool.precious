// Complex program: compute GCD using subtraction-based algorithm
// Tests: comparisons, and/or/not, nested if/elif/else, scopes, arithmetic

we_haves a = 48;
we_haves b = 18;
we_haves temp = 0;

// swap so a >= b
if (a < b) {
    temp = a;
    a = b;
    b = temp;
}

// GCD by repeated subtraction
we_haves done = 0;
if (b == 0) {
    done = 1;
}
if (!done) {
    we_haves remainder = 0;
    // compute a mod b via subtraction loop (unrolled a few times for stress)
    we_haves counter = 0;
    if (a >= b and !(a < b)) {
        counter = 1;
    }
    if (a > b and b > 0) {
        counter = counter + 1;
    }
    if (a != b and b != 0) {
        counter = counter + 1;
    }
    // verify counter logic: should be 3 if a > b and b > 0
    we_haves check = 0;
    if (counter == 3) {
        check = 100;
    }
    if (counter != 3 or a == b) {
        check = check + 1;
    }
    gives(check);
}

// should not reach here
gives(99);
