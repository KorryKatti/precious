// Test 1: and operator
we_haves x = 5;
we_haves result = 0;
if (x > 0 and x < 10) {
    result = result + 1;
}
// Test 2: or operator
if (x < 3 or x > 3) {
    result = result + 2;
}
// Test 3: not operator
if (!0) {
    result = result + 4;
}
// Test 4: not with true value
we_haves flag = 1;
if (!flag) {
    result = result + 8;
} else {
    result = result + 16;
}
gives(result);
