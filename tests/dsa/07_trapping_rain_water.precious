// LeetCode #42: Trapping Rain Water
// Calculate trapped rain water
// Expected: 6 units of water

my height: number[12] = [0, 1, 0, 2, 1, 0, 1, 3, 2, 1, 2, 1];
my n = 12;
my total = 0;
my i = 0;
while (i < n) {
    my left_max = height[i];
    my j = 0;
    while (j < i) {
        if (height[j] > left_max) {
            left_max = height[j];
        }
        j = j + 1;
    }
    my right_max = height[i];
    my k = i + 1;
    while (k < n) {
        if (height[k] > right_max) {
            right_max = height[k];
        }
        k = k + 1;
    }
    my water = 0;
    if (left_max < right_max) {
        water = left_max - height[i];
    } else {
        water = right_max - height[i];
    }
    if (water > 0) {
        total = total + water;
    }
    i = i + 1;
}
say(total);
gives(total);
