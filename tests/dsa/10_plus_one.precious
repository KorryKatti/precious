// LeetCode #66: Plus One
// Add one to the number represented by digits
// digits = [1,2,3], Expected: [1,2,4]

my digits: number[3] = [1, 2, 3];
my n = 3;
my i = n - 1;
while (i >= 0) {
    if (digits[i] < 9) {
        digits[i] = digits[i] + 1;
        my idx = 0;
        while (idx < n) {
            say(digits[idx]);
            idx = idx + 1;
        }
        gives(1);
    }
    digits[i] = 0;
    i = i - 1;
}
say(1);
my idx = 0;
while (idx < n) {
    say(digits[idx]);
    idx = idx + 1;
}
gives(1);
