// LeetCode #15: 3Sum (count triplets)
// Find all unique triplets that sum to 0
// Expected count: 2

my neg1 = 0 - 1;
my neg4 = 0 - 4;
my nums: number[6] = [neg1, 0, 1, 2, neg1, neg4];
my n = 6;
my count = 0;
my i = 0;
while (i < n - 2) {
    my j = i + 1;
    while (j < n - 1) {
        my k = j + 1;
        while (k < n) {
            if (nums[i] + nums[j] + nums[k] == 0) {
                count = count + 1;
            }
            k = k + 1;
        }
        j = j + 1;
    }
    i = i + 1;
}
// Triplets: (-1,0,1), (-1,2,-1), (0,1,-1) = 3 total
say(count);
gives(count);
