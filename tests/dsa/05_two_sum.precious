// LeetCode #1: Two Sum (Brute Force O(n^2))
// Find two numbers that add to target
// Expected: indices 0 and 1 (2+7=9)

my nums: number[4] = [2, 7, 11, 15];
my target = 9;
my found = 0;
my i = 0;
while (i < 4 and found == 0) {
    my j = i + 1;
    while (j < 4 and found == 0) {
        if (nums[i] + nums[j] == target) {
            say(i);
            say(j);
            found = 1;
        }
        j = j + 1;
    }
    i = i + 1;
}
gives(found);
