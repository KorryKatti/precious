{
    "name": "Precious",
    "scopeName": "source.precious",
    "fileTypes": ["precious"],
    "patterns": [
        {
            "include": "#comments"
        },
        {
            "include": "#strings"
        },
        {
            "include": "#numbers"
        },
        {
            "include": "#keywords"
        },
        {
            "include": "#types"
        },
        {
            "include": "#builtins"
        },
        {
            "include": "#booleans"
        },
        {
            "include": "#function-call"
        },
        {
            "include": "#operators"
        },
        {
            "include": "#punctuation"
        }
    ],
    "repository": {
        "comments": {
            "patterns": [
                {
                    "name": "comment.line.double-slash.precious",
                    "match": "//.*$"
                },
                {
                    "name": "comment.block.precious",
                    "begin": "/\\*",
                    "end": "\\*/"
                }
            ]
        },
        "strings": {
            "patterns": [
                {
                    "name": "string.quoted.double.precious",
                    "begin": "\"",
                    "end": "\"",
                    "patterns": [
                        {
                            "name": "constant.character.escape.precious",
                            "match": "\\\\(?:[\"\\\\/bfnrt]|u[0-9a-fA-F]{4})"
                        }
                    ]
                }
            ]
        },
        "numbers": {
            "patterns": [
                {
                    "name": "constant.numeric.float.precious",
                    "match": "\\b[0-9]+\\.[0-9]+\\b"
                },
                {
                    "name": "constant.numeric.integer.precious",
                    "match": "\\b[0-9]+\\b"
                }
            ]
        },
        "keywords": {
            "patterns": [
                {
                    "name": "keyword.control.precious",
                    "match": "\\b(if|elif|else|while|fn)\\b"
                },
                {
                    "name": "storage.type.precious",
                    "match": "\\b(my)\\b"
                }
            ]
        },
        "types": {
            "patterns": [
                {
                    "name": "support.type.precious",
                    "match": "\\b(number|word|question|decimal|letter)\\b"
                }
            ]
        },
        "builtins": {
            "patterns": [
                {
                    "name": "support.function.precious",
                    "match": "\\b(gives|say)\\b"
                }
            ]
        },
        "booleans": {
            "patterns": [
                {
                    "name": "keyword.operator.logical.precious",
                    "match": "\\b(and|or)\\b"
                },
                {
                    "name": "keyword.operator.logical.precious",
                    "match": "!"
                }
            ]
        },
        "function-call": {
            "patterns": [
                {
                    "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()",
                    "captures": {
                        "1": {
                            "name": "entity.name.function.precious"
                        }
                    }
                }
            ]
        },
        "operators": {
            "patterns": [
                {
                    "name": "keyword.operator.comparison.precious",
                    "match": "(==|!=|<=|>=|<|>)"
                },
                {
                    "name": "keyword.operator.assignment.precious",
                    "match": "="
                },
                {
                    "name": "keyword.operator.arithmetic.precious",
                    "match": "(\\+|-|\\*|/)"
                }
            ]
        },
        "punctuation": {
            "patterns": [
                {
                    "name": "punctuation.terminator.precious",
                    "match": ";"
                },
                {
                    "name": "punctuation.section.block.begin.precious",
                    "match": "\\{"
                },
                {
                    "name": "punctuation.section.block.end.precious",
                    "match": "\\}"
                },
                {
                    "name": "punctuation.definition.parameters.begin.precious",
                    "match": "\\("
                },
                {
                    "name": "punctuation.definition.parameters.end.precious",
                    "match": "\\)"
                },
                {
                    "name": "punctuation.definition.array.begin.precious",
                    "match": "\\["
                },
                {
                    "name": "punctuation.definition.array.end.precious",
                    "match": "\\]"
                },
                {
                    "name": "punctuation.separator.type-annotation.precious",
                    "match": ":"
                },
                {
                    "name": "punctuation.separator.comma.precious",
                    "match": ","
                }
            ]
        }
    }
}
